generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String      @id @default(uuid())
  email     String      @unique
  username  String?     @unique
  name      String?
  firstName String?
  lastName  String?
  birthDate DateTime?
  password  String?
  emailVerified DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @default(now()) @updatedAt
  goals     Goal[]
  entries   GoalEntry[]
  events    Event[]
  rules     Rule[]
  scores    Score[]
  modules   Module[]
  moduleEntries ModuleEntry[]
  streakDays StreakDay[]
  accounts  Account[]
  sessions  Session[]
}

model Goal {
  id            String        @id @default(uuid())
  user          User          @relation(fields: [userId], references: [id])
  userId        String
  title         String
  description   String?
  type          String        @default("BOOLEAN")
  status        String        @default("ACTIVE")
  icon          String        @default("star")
  color         String        @default("slate")
  order         Int?          @default(0)
  pointsIfTrue  Float?        @default(1)
  pointsIfFalse Float?        @default(0)
  pointsPerUnit Float?
  isActive      Boolean       @default(true)
  deactivatedAt DateTime?
  activatedAt   DateTime      @default(now())
  createdAt     DateTime      @default(now())
  // Días de la semana: array de 0-6 (0=domingo, 6=sábado). Si está vacío = todos los días
  weekDays      Int[]         @default([])
  entries       GoalEntry[]
  events        Event[]
}

model GoalEntry {
  id           String   @id @default(uuid())
  user         User     @relation(fields: [userId], references: [id])
  userId       String
  goal         Goal     @relation(fields: [goalId], references: [id])
  goalId       String
  date         DateTime
  valueFloat   Float?
  valueBoolean Boolean?
  createdAt    DateTime @default(now())

  @@unique([goalId, date], name: "goal_date_unique")
}

model Event {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  goal       Goal?    @relation(fields: [goalId], references: [id])
  goalId     String?
  module     Module?  @relation(fields: [moduleId], references: [id])
  moduleId   String?
  type       String
  value      Float
  metadata   String   @default("{}")
  createdAt  DateTime @default(now())
}

model Rule {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  target      String
  condition   String
  action      String
  priority    Int      @default(0)
  active      Boolean  @default(true)
  config      String?
  createdAt   DateTime @default(now())
}

model Score {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  date       DateTime
  points     Float
  createdAt  DateTime  @default(now())
}

model StreakDay {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  date      DateTime
  source    String   @default("home")
  createdAt DateTime @default(now())

  @@unique([userId, date], name: "user_date_streak_unique")
}

model Module {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  name        String
  slug        String
  description String?
  active      Boolean  @default(true)
  config      String   @default("{}")
  createdAt   DateTime @default(now())
  events      Event[]
  entries     ModuleEntry[]

  @@unique([userId, slug])
}

model ModuleEntry {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  module    Module   @relation(fields: [moduleId], references: [id])
  moduleId  String
  date      DateTime
  data      String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([moduleId, date])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
